{
  "name": "pi-diff-review",
  "version": "0.1.15",
  "description": "Local diff review TUI extension for pi",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmpadden/pi-diff-review.git"
  },
  "homepage": "https://github.com/cmpadden/pi-diff-review#readme",
  "bugs": {
    "url": "https://github.com/cmpadden/pi-diff-review/issues"
  },
  "keywords": [
    "code-review",
    "git-diff",
    "pi",
    "pi-coding-agent",
    "pi-extension",
    "pi-package"
  ],
  "files": [
    "extensions",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "npm run typecheck && npm test",
    "format": "prettier --write .",
    "precommit": "npm run check && npx prettier --check .",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.1",
    "@earendil-works/pi-tui": "^0.74.1",
    "@types/node": "^24.12.4",
    "prettier": "^3.5.3",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    }
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "image": "https://github.com/user-attachments/assets/3fd00163-5d19-489b-94ed-3d4816c6cad3"
  },
  "dependencies": {
    "@pierre/diffs": "^1.1.21"
  }
}
